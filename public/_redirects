# Cloudflare Pages redirects
# Evaluated top-to-bottom, first match wins.
# Syntax: <from> <to> <status>
#   - 301 = permanent
#   - 301! (with !) forces the redirect even if a static file exists at the path
# Replaces server/middleware/www-redirect.ts and nitro.routeRules entries.

# www → apex
https://www.silkride.co.uk/*  https://silkride.co.uk/:splat  301!

# Moved/renamed pages (fixes GSC 404s)
/booking/customer       /customer   301
/booking/customer/      /customer   301
/our-partners           /partners   301
/our-partners/          /partners   301
/testimonials           /           301
/testimonials/          /           301
/Luxury                 /           301
/Luxury/                /           301
